#!/bin/zsh

alias ls="lsd -A --icon never --group-directories-first"
alias ll="lsd -Alh --icon never --group-directories-first"
alias grep="grep --color=auto"
alias diff="diff --color=auto"
alias cat="bat --style=numbers --color=always"
alias cp="cp -rfv"
alias mv="mv -fv"
alias rm="rm -rfv"
alias mkdir="mkdir -pv"
alias pac="paru"
alias open="$OPENER"
alias ex="unar"

function chpwd() {
	lsd -A --icon never --group-directories-first
}
