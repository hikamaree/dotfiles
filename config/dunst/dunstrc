[global]
frame_width = 1
frame_color = "#61AFEF"
font = JetBrains Mono 11
offset = 20x20
format = "<b>%s</b>\n%b"
alignment = center
gaps = true
gap_size = 4

[urgency_low]
background = "#000000"
foreground = "#C0CAF5"
history_ignore = true
timeout = 1

[urgency_normal]
background = "#000000"
foreground = "#C0CAF5"
timeout = 5

[urgency_critical]
background = "#ff0000FF"
foreground = "#000000"
timeout = 10
