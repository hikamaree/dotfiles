#!/bin/sh

# copy config files
mv ~/.config ~/.old_config
mv ~/.local ~/.old_local
mv ~/.mozilla ~/.old_mozilla

mkdir -p ~/Documents
mkdir -p ~/Downloads
mkdir -p ~/Music
mkdir -p ~/Pictures/screenshots
mkdir -p ~/.local/share/zsh
mkdir -p ~/.local/share/mpd

cp -rf ./Icons ~/.local/share/icons
cp -rf ./Themes ~/.local/share/themes

sudo pacman --noconfirm -Syu

# hyprland
sudo pacman -S --noconfirm hyprland hyprpaper hypridle hyprlock wl-clipboard \
	xdg-desktop-portal-gtk xdg-desktop-portal-wlr vulkan-radeon libva-mesa-driver
# apps
sudo pacman -S --noconfirm zsh alacritty neovim valgrind htop lf fzf zip unzip stow \
	rustup waybar dunst swayimg ncmpcpp mpd mpc mpv man-db fuzzel flatpak firefox

#link config
stow --no-folding --ignore="yay|Icons|Themes|rules|install|system" --adopt .

sudo systemctl enable seatd.service
sudo systemctl mask backlight@.service
sudo systemctl mask --global at-spi-dbus-bus.service

#aur
git clone http://aur.archlinux.org/yay.git
cd yay
makepkg -si --noconfirm
cd ..

yay -S --noconfirm hyprshot ttf-exo-2 ttf-sourcecodepro-nerd

# flatpaks
flatpak override --user --filesystem=xdg-data/themes
flatpak override --user --filesystem=xdg-data/icons
flatpak override --user --env=GTK_THEME=Orchis-Dark
flatpak override --user --socket=wayland

#theme
gsettings set org.gnome.desktop.interface gtk-theme 'Orchis-Dark'
gsettings set org.gnome.desktop.interface font-name 'Exo 2 11'
gsettings set org.gnome.desktop.interface cursor-theme 'Future-dark-cursors'

# shell
sudo ./system $USER
chsh -s /bin/zsh

exit
