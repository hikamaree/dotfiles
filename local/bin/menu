#!/bin/sh

programi="󰖟   librewolf\n󰙯   discord\n   foot\n   lf\n   ncmpcpp\n   htop\n󱇧   xournalpp\n󰿅   logout\n󰤆   poweroff"

program=$(echo -e "$programi" | bemenu -i -H 28 -l 20 -c -W 0.2 -B 1 -R 10 -n --fn "Exo 2 16" -p '' --tb '#1a1b26' --fb '#1a1b26' --fbb '#1a1b26' --sb '#1a1b26' --nb '#1a1b26' --ab '#1a1b26' --sb '#16161e' --hb '#16161e' --bdr '#16161e' --ff '#80c0d0' --nf '#80c0d0' --af '#80c0d0' --fbf '#80c0d0' --hf '#7aa2f7' --cw 2)

case "$program" in 
	"󰖟   librewolf") librewolf;;
	"󰙯   discord") webcord --enable-features=UseOzonePlatform --ozone-platform=wayland;;
	"󰓓   steam") steam;;
	"󰍳   minecraft") minecraft-launcher;;
	"   foot") foot;;
	"   lf") foot lf;;
	"   ncmpcpp") foot ncmpcpp;;
	"   htop") foot htop;;
	"   logisim") logisim;;
	"󱇧   xournalpp") xournalpp;;
	"󰿅   logout") hyprctl dispatch exit;;
	"󰤆   poweroff") poweroff;;
	*) eval $program;;
esac
